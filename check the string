class Solution:
    def checkStrings(self, s1: str, s2: str) -> bool:
        # Separate characters by index parity and compare sorted versions
        # Even positions: 0, 2, 4...
        # Odd positions: 1, 3, 5...
        return sorted(s1[0::2]) == sorted(s2[0::2]) and \
               sorted(s1[1::2]) == sorted(s2[1::2])
