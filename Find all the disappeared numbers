from typing import List

class Solution:
    def findDisappearedNumbers(self, nums: List[int]) -> List[int]:
        """
        Finds all numbers in the range [1, n] that do not appear in the array.
        This solution uses an in-place modification approach with O(1) extra space
        and O(n) time complexity. The output list does not count as extra space.
        """
        # Iterate over each element in the original array
        for num in nums:
            # Use the absolute value of the number to get the index.
            # Subtract 1 because the numbers are 1-based, and indices are 0-based.
            index = abs(num) - 1
            # If the value at this index is positive, mark it as visited by negating it.
            # This indicates that the number (index + 1) is present in the array.
            if nums[index] > 0:
                nums[index] *= -1 #

        # A list to store the missing numbers.
        result = []
        # Iterate through the array again to find the positive numbers.
        # The indices of positive numbers correspond to the missing numbers.
        for i in range(len(nums)):
            if nums[i] > 0:
                # Add the missing number (index + 1) to the result list.
                result.append(i + 1) #

        return result
